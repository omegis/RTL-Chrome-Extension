{
  "manifest_version": 3,
  "name": "Rotem Daily RTL",
  "version": "2.6.1",
  "description": "Automatically applies RTL text direction for Hebrew content on supported websites.",
  "author": "Rotem Bar",
  "homepage_url": "https://github.com/omegis/RTL-Chrome-Extension",
  "permissions": ["storage", "tabs"],
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icon16.png",
      "48": "icon48.png",
      "128": "icon128.png"
    }
  },
  "icons": {
    "16": "icon16.png",
    "48": "icon48.png",
    "128": "icon128.png"
  },
  "content_scripts": [
    {
      "matches": ["https://www.notion.so/*", "https://claude.ai/*", "https://gemini.google.com/*", "https://dash.bunny.net/*", "https://app.manychat.com/*", "https://creators.spotify.com/*"],
      "js": ["content.js"]
    }
  ]
}
